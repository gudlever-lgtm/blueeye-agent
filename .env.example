# BlueEye Agent configuration
# Copy to .env and adjust for the device this agent runs on.

# URL of the BlueEye server (mTLS endpoint).
BLUEEYE_SERVER_URL=https://localhost:8443

# Client certificate / key used to authenticate to the server.
# The certificate Common Name (CN) is the agent's identity.
CLIENT_CERT=certs/agent-001.crt
CLIENT_KEY=certs/agent-001.key

# CA certificate used to verify the server.
CA_CERT=certs/ca.crt

# Seconds between job polls.
POLL_INTERVAL=30

# Where this switch/agent lives. Shown on the server dashboard so outages
# can be traced to a physical location and uplink.
AGENT_LOCATION=HQ - Floor 1
AGENT_CONNECTION=core-uplink-1
