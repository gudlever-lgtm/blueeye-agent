# BlueEye agent — environment configuration.
# Env vars override values from the JSON config file (see config.example.json).

# Path to the JSON config file (optional; default ./blueeye-agent.config.json)
BLUEEYE_AGENT_CONFIG=./blueeye-agent.config.json

# Server to connect to
BLUEEYE_SERVER_URL=http://localhost:3000

# One-time enrollment code — only needed for the very first start.
# After enrollment the agent stores a token and this can be removed.
BLUEEYE_ENROLLMENT_CODE=

# Where the issued agent token is stored (created with 0600 permissions)
BLUEEYE_TOKEN_PATH=./.blueeye-agent/token

# Tuning
BLUEEYE_HEARTBEAT_MS=15000
BLUEEYE_RECONNECT_BASE_MS=1000
BLUEEYE_RECONNECT_MAX_MS=30000
BLUEEYE_LOG_LEVEL=info
