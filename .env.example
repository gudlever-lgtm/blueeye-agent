# Påkrævet — WebSocket-adresse til BlueEye Server
SERVER_URL=ws://server-ip:4000

# Valgfri — unikt agent-id (default: os.hostname())
AGENT_ID=min-unikke-agent-id

# Valgfri — reconnect-interval i ms (default: 5000)
RECONNECT_INTERVAL_MS=5000

# Valgfri — timeout for systemkommandoer i ms (default: 30000)
TEST_TIMEOUT_MS=30000
